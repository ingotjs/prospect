{
  "private": true,
  "homepage": "https://ingot.js.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/ingotjs/prospect.git"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun run --cwd apps/playground dev",
    "build": "bun run --cwd apps/playground build",
    "test": "bun test",
    "e2e": "bun run --cwd apps/playground e2e",
    "ok": "vp fmt --write && vp lint --fix && tsc --noEmit",
    "ok:ci": "vp fmt --check && vp lint && tsc --noEmit",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@types/node": "22.15.3",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.3",
    "typescript": "5.8.3",
    "ultracite": "7.4.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.15",
    "vite-plus": "0.1.14"
  },
  "packageManager": "bun@1.3.10"
}
